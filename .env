PORT=4003
NODE_ENV=development

# MONGODB_URI=mongodb://127.0.0.1:27017/completehome
MONGODB_URI=mongodb+srv://appcompletehome_db_user:<db_password>@complete-home-cluster.jsmqlox.mongodb.net/?appName=complete-home-Cluster
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_ACCESS_EXPIRES=25m
JWT_REFRESH_EXPIRES=7d

# Seeded admin (see npm run seed)
SEED_ADMIN_USER_ID=USR41472786
SEED_ADMIN_PASSWORD=securepassword123

# ==========================
# Development
# ==========================
# CORS_ORIGIN=http://localhost:5173,http://localhost:5174
# FRONTEND_URL=http://localhost:5173

